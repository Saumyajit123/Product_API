<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>
        <%=title%>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>

<body>
    <div class="container">
        <h2>List of All Products</h2>
        <a href="/product/add" class="btn btn-primary">Add Product</a>
        <table class="table">
            <thead>
                <tr>
                    <th scope="col">#</th>
                    <th scope="col">Name</th>
                    <th scope="col">Description</th>
                    <th scope="col">Short Description</th>
                    <th scope="col">Brand</th>
                    <th scope="col">Categoty</th>
                    <th scope="col">Price</th>
                    <th scope="col">Discount</th>
                    <th scope="col">Currency</th>
                    <th scope="col">Tag</th>
                    <th scope="col">Status</th>
                    <th scope="col">Deleted?</th>
                </tr>
            </thead>
            <tbody>
                <% data.forEach((product, index)=> {%>
                    <tr>
                        <th scope="row">
                            <%= index + 1 %>
                        </th>
                        <td>
                            <% if(product.image){ %>
                                <img src="/uploads/<%= product.image %>" alt="product" width="60" height="60"
                                    style="border-radius:50%; object-fit:cover;">
                                <% } else { %>
                                    No Image
                                    <% } %>
                        </td>
                        <td>
                            <%= product.name %>
                        </td>
                        <td>
                            <%= product.description %>
                        </td>
                        <td>
                            <%= product.shortDescription %>
                        </td>
                        <td>
                            <%= product.brand %>
                        </td>
                        <td>
                            <%= product.category %>
                        </td>
                        <td>
                            <%= product.price %>
                        </td>
                        <td>
                            <%= product.discountPrice %>
                        </td>
                        <td>
                            <%= product.currency %>
                        </td>
                        <td>
                            <%= product.tag %>
                        </td>
                        <td>
                            <%= product.status %>
                        </td>
                        <td>
                            <%= product.isDeleted %>
                        </td>
                        <td class="d-flex justify-content-center align-items-center">
                            <a href="/product/view/<%= product._id %>" class="btn btn-success me-2">View</a>
                            <a href="/product/update/<%= product._id %>" class="btn btn-primary me-2">Update</a>
                            <a href="/product/delete/<%= product._id %>" class="btn btn-danger">Delete</a>
                        </td>
                    </tr>
                    <%} ) %>
            </tbody>
        </table>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
</body>

</html>