<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>
        <%=title%>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>

<body>
    <h2 class="text-center">Add Product</h2>
    <div class="container mt-5">
        <div class="row justify-content-center">

            <div class="col-md-6">

                <form action="/product/create" method="POST" enctype="multipart/form-data">

                    <div class="mb-3 row">
                        <label class="col-sm-3 col-form-label">Name:</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" name="name">
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label class="col-sm-3 col-form-label">Description</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" name="description">
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label class="col-sm-3 col-form-label">Short Description:</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" name="shortDescription">
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label class="col-sm-3 col-form-label">Brand:</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" name="brand">
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label class="col-sm-3 col-form-label">Category:</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" name="category">
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label class="col-sm-3 col-form-label">Price:</label>
                        <div class="col-sm-9">
                            <input type="number" class="form-control" name="price">
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label class="col-sm-3 col-form-label">Discount price:</label>
                        <div class="col-sm-9">
                            <input type="number" class="form-control" name="discountPrice">
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label class="col-sm-3 col-form-label">Currency:</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" name="currency">
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label class="col-sm-3 col-form-label">Tag:</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" name="tag">
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label class="col-sm-3 col-form-label">Status:</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" name="status">
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label class="col-sm-3 col-form-label">Is Deleted ?:</label>
                        <div class="col-sm-9">
                            <select name="isDeleted" class="form-control">
                                <option value="true" <%=product.isDeleted ? "selected" : "" %>>Yes</option>
                                <option value="false" <%=!product.isDeleted ? "selected" : "" %>>No</option>
                            </select>
                        </div>
                    </div>


                    <!-- File Upload -->
                    <div class="mb-3 row">
                        <div class="offset-sm-3 col-sm-9">
                            <input type="file" class="form-control" name="image">
                        </div>
                    </div>

                    <!-- Submit Button -->
                    <div class="row">
                        <div class="offset-sm-3 col-sm-9 text-center">
                            <button type="submit" class="btn btn-primary">
                                Add
                            </button>
                        </div>
                    </div>

                </form>

            </div>

        </div>
    </div>

    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
</body>

</html>